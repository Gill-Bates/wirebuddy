# WireBuddy Configuration
# Copy this file to .env and adjust values.

# -----------------------------------------------------------------------------
# Core App
# -----------------------------------------------------------------------------

# Required in master mode.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WIREBUDDY_SECRET_KEY=

# master | node
SERVER_MODE=master

# CRITICAL | ERROR | WARNING | INFO | DEBUG
LOG_LEVEL=INFO

# Application timezone for UI/scheduler formatting, e.g. Europe/Berlin
TZ=UTC

# Development only: enable uvicorn reload
# WIREBUDDY_DEV_RELOAD=false

# Development/debug only: skip startup network sanity checks
# WIREBUDDY_SKIP_NETWORK_CHECK=false


# -----------------------------------------------------------------------------
# Reverse Proxy / Cookie Behavior
# -----------------------------------------------------------------------------

# Comma-separated trusted proxy CIDRs for forwarded client IP handling.
# Default in code: 127.0.0.0/8,::1/128
# TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128

# Force secure cookies even when the request is not detected as HTTPS.
# Useful behind TLS-terminating reverse proxies.
# FORCE_HTTPS_COOKIES=false

# Explicit trusted proxy CIDRs for the public /status page only.
# WIREBUDDY_STATUS_TRUSTED_PROXY_CIDRS=

# Comma-separated proxy IPs/CIDRs trusted by Uvicorn for X-Forwarded-* headers.
# Keep this restricted to your actual reverse proxy addresses.
# FORWARDED_ALLOW_IPS=127.0.0.1


# -----------------------------------------------------------------------------
# Passkeys / WebAuthn
# -----------------------------------------------------------------------------

# Override relying party ID and name if host-based auto-detection is not desired.
# PASSKEY_RP_ID=
# PASSKEY_RP_NAME=WireBuddy

# Maximum passkeys per user.
# MAX_PASSKEYS_PER_USER=20


# -----------------------------------------------------------------------------
# GeoIP Overrides
# -----------------------------------------------------------------------------

# Optional explicit paths to MaxMind MMDB files.
# WIREBUDDY_GEOIP_DB_PATH=/opt/wirebuddy/data/geolite2/GeoLite2-City.mmdb
# WIREBUDDY_ASN_DB_PATH=/opt/wirebuddy/data/geolite2/GeoLite2-ASN.mmdb


# -----------------------------------------------------------------------------
# Node Mode Only
# -----------------------------------------------------------------------------

# Node runtime environment name. Production requires verify key for enrollment.
# WIREBUDDY_ENV=production

# Initial bootstrap token and optional local verification key.
# WIREBUDDY_ENROLLMENT_TOKEN=
# WIREBUDDY_ENROLLMENT_VERIFY_KEY=

# Optional custom CA bundle for master API TLS validation.
# WIREBUDDY_MASTER_CA_FILE=/app/data/certs/master-ca.pem

# Sync timing overrides (seconds).
# WIREBUDDY_NODE_SYNC_INTERVAL=30
# WIREBUDDY_NODE_SYNC_INTERVAL_FAST=5
# WIREBUDDY_ENROLLMENT_RETRY_ATTEMPTS=3

# Node/firewall overrides.
# WG_CONFIG_PATH=/etc/wireguard
# WIREBUDDY_NO_FIREWALL_FIX=false


# -----------------------------------------------------------------------------
# Test / CI / Development Internals
# -----------------------------------------------------------------------------

# Used by tests/helpers only.
# TESTING=1

# Relax GeoIP minimum size checks for fixtures/smoke tests.
# WIREBUDDY_TEST_MODE=1
# WIREBUDDY_MIN_GEOIP_SIZE=100000